# AWS auth (for DynamoDB when SCRAPER_PERSIST_TO_DDB=true)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1

# LLM — Lean translation uses OpenAI (required for --lean flag)
OPENAI_API_KEY=your-openai-api-key

# DynamoDB table (used when SCRAPER_PERSIST_TO_DDB=true)
DDB_TABLE_PROBLEM=hyperbeam-problem

# Persistence toggle
SCRAPER_PERSIST_TO_DDB=false
