# AWS auth (for DynamoDB and SQS)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1

# LLM — Lean translation uses OpenAI (required for --lean flag)
OPENAI_API_KEY=your-openai-api-key

# Optional model proxy keys (only needed for the corresponding /api/*-proxy endpoints)
GEMINI_API_KEY=        # Google AI Studio — free tier at aistudio.google.com
ANTHROPIC_API_KEY=     # Anthropic Claude — console.anthropic.com
GROQ_API_KEY=          # Groq free tier — console.groq.com

# Data stores / queues
DDB_TABLE=hyperbeam-main
DDB_TABLE_PROBLEM=hyperbeam-problem
DDB_TABLE_SCORE=hyperbeam-score
DDB_TABLE_SUBMISSION=hyperbeam-submission
DDB_TABLE_USER=hyperbeam-user
SQS_SCRAPE_QUEUE=hyperbeam-scrape-jobs
SQS_SCORE_QUEUE=hyperbeam-score-jobs

# Supabase (optional)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# API secret for backend auth
API_SECRET_KEY=changeme

# CORS allowed origin for frontend
FRONTEND_URL=http://localhost:5173

# Worker: rewrite public-IP proxy URLs to localhost so requests don't loop through
# the internet gateway. Set this to http://localhost:8000 on EC2.
WORKER_API_SELF_URL=http://localhost:8000
