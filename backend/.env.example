# AWS auth
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1

# LLM endpoint (SageMaker JumpStart/TGI)
SAGEMAKER_ENDPOINT_NAME=your-sagemaker-endpoint
OPENAI_API_KEY=                  # optional fallback

# Data stores / queues
DDB_PROBLEM=hyperbeam-problem
DDB_SCORE=hyperbeam-score
DDB_SUBMISSION=hyperbeam-submission
DDB_USER=hyperbeam-user
SQS_SCRAPE_QUEUE=hyperbeam-scrape-jobs
SQS_SCORE_QUEUE=hyperbeam-score-jobs

# Supabase (optional)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# API secret for backend auth
API_SECRET_KEY=changeme

# CORS allowed origin for frontend
FRONTEND_URL=http://localhost:5173
